# Imagem publicada pelo pipeline do repositório privado
APP_IMAGE=ghcr.io/rodriguinhopbs/censo_psico_nr1
APP_IMAGE_TAG=latest

# Porta HTTP da aplicacao no host cliente
APP_PORT=8000

# Banco de dados
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=censopsico

# Flask
FLASK_ENV=production
SECRET_KEY=gere-uma-chave-forte-e-unica

# Cookies de sessao
SESSION_COOKIE_SECURE=true
REMEMBER_COOKIE_SECURE=true

# IA (opcional)
OLLAMA_ENABLED=false
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b
OPENAI_API_KEY=
