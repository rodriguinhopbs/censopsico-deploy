# Imagem publicada pelo pipeline do repositório privado
APP_IMAGE=ghcr.io/rodriguinhopbs/censo_psico_nr1
APP_IMAGE_TAG=latest

# Nome do projeto Compose (use o mesmo nome do ambiente antigo para reaproveitar volumes)
COMPOSE_PROJECT_NAME=censo_psico_nr1

# Portas de borda (Nginx)
HTTP_PORT=80
HTTPS_PORT=443

# Banco de dados
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=censopsico

# Flask
FLASK_ENV=production
SECRET_KEY=gere-uma-chave-forte-e-unica

# Administrador inicial do sistema
SYSTEM_ADMIN_EMAIL=admin@censopsico.com
SYSTEM_ADMIN_PASSWORD=troque-esta-senha
SYSTEM_ADMIN_NAME=Administrador do Sistema
SYSTEM_ADMIN_COMPANY_NAME=Organizacao Inicial

# Cookies de sessao
SESSION_COOKIE_SECURE=true
REMEMBER_COOKIE_SECURE=true

# IA (opcional)
OLLAMA_ENABLED=false
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b
OPENAI_API_KEY=

# Rate limit (Flask-Limiter) com backend compartilhado
RATELIMIT_STORAGE_URI=redis://redis:6379/0
